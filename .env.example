VITE_SUPABASE_PROJECT_ID="your_supabase_project_id"
VITE_SUPABASE_PUBLISHABLE_KEY="your_supabase_publishable_key"
# For development you can point the client at the Vite proxy (see vite.config.ts):
# Set VITE_SUPABASE_URL=/supabase and configure VITE_SUPABASE_PROXY_TARGET to
# your real Supabase project URL (e.g. https://<project>.supabase.co). This
# allows the browser to talk to the local dev server which forwards requests
# to Supabase, avoiding CORS issues during development.
VITE_SUPABASE_URL="/supabase"

# Real Supabase project URL used by the Vite dev proxy. Do NOT commit real
# secrets into source control; put them in a local .env file or CI secrets.
VITE_SUPABASE_PROXY_TARGET="https://your-project.supabase.co"

# client-side API keys
VITE_YOUTUBE_API_KEY="your_youtube_api_key"
VITE_TURNSTILE_SITE_KEY="your_turnstile_site_key"

# Optional keys used by server-side functions (supabase/functions)
GEMINI_API_KEY="your_gemini_api_key"
YOUTUBE_API_KEY="your_youtube_api_key"
TURNSTILE_SECRET_KEY="your_turnstile_secret_key"

# (The VITE_ prefix is for client-side; functions read the non-prefixed values above.)